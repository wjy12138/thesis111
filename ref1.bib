  shorttitle = {Data Processing Strategies in Wind Energy Forecasting Models and Applications},
  author = {Liu, Hui and Chen, Chao},
  date = {2019-09},
  journaltitle = {Applied Energy},
  shortjournal = {Applied Energy},
  volume = {249},
  pages = {392--408},
  issn = {03062619},
  doi = {10.1016/j.apenergy.2019.04.188},
  url = {https://linkinghub.elsevier.com/retrieve/pii/S0306261919308517},
  urldate = {2026-03-04},
  abstract = {Given the intermittent nature of the wind, accurate wind energy forecasting is significant to the proper utilization of renewable energy sources. In recent years, data-driven models based on past observations have been widely employed in the literature. Various types of data processing methods are successfully applied to assist these models and further improve forecasting performance. Comprehensive research of their methodologies is called on for a thorough understanding of current challenges that affect model accuracy and efficiency. To address the knowledge gap, this paper presents an exhaustive review and categorization of data processing in wind energy forecasting. The utilized techniques are classified into seven categories according to the applications: decomposition, feature selection, feature extraction, denoising, residual error modeling, outlier detection, and filter-based correction. An overall analysis of their intentions, positions, characteristics, and implementation details is provided. A general evaluation is carried out from different perspectives including accuracy improvement, usage frequency, consuming time, robustness to parameters, maturity, and implementation difficulty. Among the existing data processing methods, outlier detection and filter-based correction are relatively less used. Their potential can be better explored in the future. Furthermore, some possible research directions and challenges of data processing in wind energy forecasting are provided, in order to encourage subsequent research.},
  langid = {english},
  annotation = {abstractTranslation: 考虑到风能的间歇性，准确的风能预测对合理利用可再生能源具有重要意义。近年来，基于过去观测的数据驱动模型在文献中得到了广泛的应用。各种类型的数据处理方法被成功地应用于辅助这些模型，并进一步提高预测性能。需要对它们的方法进行全面的研究，以深入了解当前影响模型精度和效率的挑战。为了解决这一知识缺口，本文对风能预测中的数据处理进行了详尽的回顾和分类。 所使用的技术根据应用分为七类：分解、特征选择、特征提取、去噪、残差建模、异常检测和基于滤波器的校正。对他们的意图、立场、特点和实施细节进行了全面的分析。从精度提升、使用频率、耗时、对参数的鲁棒性、成熟度和实现难度等不同角度进行了总体评估。在现有的数据处理方法中，离群点检测和基于过滤器的校正使用相对较少。未来可以更好地发掘他们的潜能。 此外，还提出了风能预测中数据处理的一些可能的研究方向和挑战，以鼓励后续的研究。},
  file = {C:\Users\73283\Zotero\storage\Z9XLALKN\Liu和Chen - 2019 - Data processing strategies in wind energy forecasting models and applications A comprehensive revie.pdf}
}

@article{liuDeterministicWindEnergy2019,
  title = {Deterministic Wind Energy Forecasting: {{A}} Review of Intelligent Predictors and Auxiliary Methods},
  shorttitle = {Deterministic Wind Energy Forecasting},
  author = {Liu, Hui and Chen, Chao and Lv, Xinwei and Wu, Xing and Liu, Min},
  date = {2019-09},
  journaltitle = {Energy Conversion and Management},
  shortjournal = {Energy Conversion and Management},
  volume = {195},
  pages = {328--345},
  issn = {01968904},
  doi = {10.1016/j.enconman.2019.05.020},
  url = {https://linkinghub.elsevier.com/retrieve/pii/S0196890419305655},
  urldate = {2026-03-04},
  abstract = {Recent developments in renewable energy have highlighted the need for rational use of wind energy. Accurate prediction of wind speed and wind power is recognized as an essential part in realizing energy balance and scheduling decisions of power generation. In recent years, various wind energy forecasting models have been successfully proposed. Among them, intelligent models occupy an irreplaceable dominance and have tremendous potential due to their accuracy and robustness. This paper gives a broad literature survey of the intelligent predictors in the field of wind energy forecasting, including four types of shallow predictors (artificial neural network, extreme learning machine, support vector machine, and fuzzy logic model) and four types of deep learning-based predictors (autoencoder, restricted Boltzmann machine, convolutional neural network, and recurrent neural network). Their theoretical backgrounds, applications, merits, and limitations are thoroughly discussed. Then, two commonly used auxiliary methods for hybrid intelligent models are reviewed, i.e., ensemble learning and metaheuristic optimization. The ensemble learning models are categorized by the sources of diversity and ensemble strategies. According to the specific optimized objects, the metaheuristic optimization algorithms are classified into two groups. Moreover, the general process of metaheuristic optimization and differences between single-objective and multi-objective algorithms are also clarified. A group of representative models is summarized to show the frameworks of mainstream predictive models in artificial intelligence. Finally, this paper gives three possible development directions of wind energy forecasting for subsequent research.},
  langid = {english},
  annotation = {abstractTranslation: 最近可再生能源的发展强调了合理利用风能的必要性。准确预测风速和风电功率是实现能量平衡和发电调度决策的重要环节。近年来，各种风能预测模型被成功提出。其中，智能模型由于其准确性和鲁棒性，占据着不可替代的主导地位，具有巨大的潜力。 本文对风能预测领域的智能预测器进行了广泛的文献调研，包括4类浅层预测器(人工神经网络、极限学习机、支持向量机、模糊逻辑模型)和4类基于深度学习的预测器(自动编码器、受限玻尔兹曼机、卷积神经网络、循环神经网络)。详细讨论了它们的理论背景、应用、优点和局限性。然后，综述了混合智能模型的两种常用辅助方法，即集成学习和元启发式优化。集成学习模型按多样性来源和集成策略进行分类。 根据具体的优化对象，将元启发式优化算法分为两类。此外，还阐明了元启发式优化的一般过程以及单目标和多目标算法之间的差异。总结了一组具有代表性的模型，展示了人工智能中主流预测模型的框架。最后，本文为后续研究给出了风能预测的三个可能发展方向。},
  file = {C:\Users\73283\Zotero\storage\CDJBGLZF\Liu 等 - 2019 - Deterministic wind energy forecasting A review of intelligent predictors and auxiliary methods.pdf}
}

@article{niuWindPowerForecasting2020,
