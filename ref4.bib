	url = {https://doi.org/10.20153/j.issn.2096-9759.2025.11.005},
	doi = {10.20153/j.issn.2096-9759.2025.11.005},
	abstract = {针对风力发电功率预测的准确度以及可解释性上的不足，该研究构建了基于卷积神经网络（{CNN}）、长短期记忆网络（{LSTM}）和注意力机制（Attention）的风力发电功率预测模型，并采用{SHAP}（{SHapley} Additive {exPlanations}）方法对模型的可解释性进行分析。通过风力发电数据集，验证该研究提出模型的可靠性，结果表明，{CNN}-{LSTM}-Attention模型在测试集上的平均绝对误差（{MAE}）、均方误差（{MSE}）、均方根误差（{RMSE}）和决定系数（R2）分别达到0.0845、0.0175、0.1326和0.9791，显著优于单一{CNN}、{LSTM和CNN}-{LSTM模型}，进一步通过{SHAP方法分析了各特征对预测结果的影响}，为风力发电功率预测、异常检测和故障识别提供了新的方法和思路。},
	pages = {17--21},
	number = {11},
	journaltitle = {长江信息通信},
	author = {{马昕远} and {伊海港}},
	urldate = {2026-04-03},
	date = {2025},
	langid = {pinyin},
	keywords = {卷积神经网络({CNN}), 时间序列预测, 长短期记忆网络({LSTM}), 注意力机制(Attention), {SHAP可解释性}},
	file = {Full Text PDF:C\:\\Users\\yonghu1\\Zotero\\storage\\I3Q36JZ8\\马昕远和伊海港 - 2025 - 基于CNN-LSTM-Attention的风力发电功率预测与可解释性分析.pdf:application/pdf},
}

